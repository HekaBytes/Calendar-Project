      botCtx.restore();
    }

    function drawCloud(cx, cy, scale, opacity) {
      botCtx.save();
      botCtx.globalAlpha = opacity;

      const shadow = botCtx.createRadialGradient(cx, cy + scale * 0.55, 0, cx, cy + scale * 0.55, scale * 1.1);
      shadow.addColorStop(0, 'rgba(140,160,200,0.18)');
      shadow.addColorStop(1, 'rgba(140,160,200,0)');
      botCtx.fillStyle = shadow;
      botCtx.beginPath();
      botCtx.ellipse(cx, cy + scale * 0.5, scale, scale * 0.3, 0, 0, Math.PI * 2);
      botCtx.fill();

      const puffs = [
        [0,          0,          scale * 0.62],
        [-scale * 0.55, scale * 0.18, scale * 0.44],
        [ scale * 0.55, scale * 0.18, scale * 0.44],
        [-scale * 0.25, scale * 0.28, scale * 0.38],
        [ scale * 0.28, scale * 0.28, scale * 0.36],
        [0,          scale * 0.32, scale * 0.40],
      ];

      puffs.forEach(([dx, dy, r]) => {
        const g = botCtx.createRadialGradient(cx + dx - r * 0.12, cy + dy - r * 0.18, r * 0.1, cx + dx, cy + dy, r);
        g.addColorStop(0,   'rgba(255,255,255,0.96)');
        g.addColorStop(0.5, 'rgba(240,245,255,0.88)');
        g.addColorStop(1,   'rgba(210,225,250,0.55)');
        botCtx.fillStyle = g;
        botCtx.beginPath();
        botCtx.arc(cx + dx, cy + dy, r, 0, Math.PI * 2);
        botCtx.fill();
      });

      botCtx.restore();
    }

    // Each entry: [xFrac, yFrac, scaleFrac, opacity, driftSpeed, driftAmp]
    const CLOUD_CONFIGS = {
