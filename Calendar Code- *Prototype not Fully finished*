    // Star positions for bar [x, y] in a 1280×116 reference space
    const BAR_STARS = [
      [60,12],[150,28],[280,10],[420,22],[555,8],[680,18],[810,12],[940,25],
      [1080,14],[1200,32],[45,48],[210,55],[390,44],[580,40],[750,52],[960,42],[1150,54],
      [130,72],[360,80],[600,68],[840,76],[1060,70],[1230,84],
    ];

    const BAR_BRIGHT_STARS = [[240,14],[620,9],[980,18],[410,66],[880,62]];

    function getMoonProgress() {
      const now     = new Date();
      const minutes = now.getHours() * 60 + now.getMinutes() + now.getSeconds() / 60;
      if (minutes >= MOON_RISE)            return (minutes - MOON_RISE) / MOON_DUR;
      if (minutes <= MOON_SET_NEXT - 1440) return (minutes + 1440 - MOON_RISE) / MOON_DUR;
      return -1;
    }

    /** Evaluates the moon arc bezier at progress t */
    function moonArcPoint(t) {
      const W = botCanvas.width;
      const H = botCanvas.height;
      return bezierPoint(t, 0, H * 0.92, W * 0.5, H * 0.04, W, H * 0.92);
    }

    function drawMoonArcTrack() {
      const W = botCanvas.width;
      const H = botCanvas.height;
      const y = H * 0.92;

      // Horizon glow
      const glow = botCtx.createRadialGradient(W * 0.5, H, 0, W * 0.5, H, W * 0.4);
      glow.addColorStop(0, 'rgba(100,140,255,0.14)');
      glow.addColorStop(1, 'rgba(100,140,255,0)');
      botCtx.fillStyle = glow;
      botCtx.fillRect(0, H * 0.6, W, H * 0.4);

      // Arc track
      botCtx.beginPath();
      botCtx.moveTo(0, y);
      botCtx.quadraticCurveTo(W * 0.5, H * 0.04, W, y);
      botCtx.strokeStyle = 'rgba(180,210,255,0.1)';
      botCtx.lineWidth   = 1.5;
      botCtx.setLineDash([3, 9]);
      botCtx.stroke();
      botCtx.setLineDash([]);

      // Horizon line and edge ticks
      botCtx.strokeStyle = 'rgba(180,210,255,0.07)';
      botCtx.lineWidth   = 1;
      botCtx.beginPath(); botCtx.moveTo(0, y); botCtx.lineTo(W, y); botCtx.stroke();

      botCtx.strokeStyle = 'rgba(180,210,255,0.28)';
      botCtx.lineWidth   = 1.5;
      botCtx.beginPath(); botCtx.moveTo(2,     y - 5); botCtx.lineTo(2,     y + 2); botCtx.stroke();
      botCtx.beginPath(); botCtx.moveTo(W - 2, y - 5); botCtx.lineTo(W - 2, y + 2); botCtx.stroke();
    }

    function drawMoonTrail(progress) {
      if (progress <= 0) return;
      const H   = botCanvas.height;
      const end = moonArcPoint(progress);
      const mid = moonArcPoint(progress / 2);
      const scpx = 2 * mid.x - 0.5 * (0 + end.x);
      const scpy = 2 * mid.y - 0.5 * (H * 0.92 + end.y);

      botCtx.beginPath();
      botCtx.moveTo(0, H * 0.92);
      botCtx.quadraticCurveTo(scpx, scpy, end.x, end.y);
      botCtx.strokeStyle = 'rgba(200,224,255,0.28)';
      botCtx.lineWidth   = 1.6;
      botCtx.stroke();
    }

    /** Draws a phase-accurate moon disc using geometry (no emoji) */
    function drawMoonDisc(cx, cy, R, phase, opacity) {
      if (opacity < 0.02) return;
      const K = 0.5523; // bezier circle constant

      botCtx.save();
      botCtx.globalAlpha = opacity;

      // Atmospheric glow
      const glow = botCtx.createRadialGradient(cx, cy, R * 0.9, cx, cy, R * 2.6);
      glow.addColorStop(0, 'rgba(190,215,255,0.28)');
      glow.addColorStop(1, 'rgba(190,215,255,0)');
      botCtx.fillStyle = glow;
      botCtx.beginPath();
      botCtx.arc(cx, cy, R * 2.6, 0, Math.PI * 2);
      botCtx.fill();

      // Clip to disc
      botCtx.save();
      botCtx.beginPath();
      botCtx.arc(cx, cy, R, 0, Math.PI * 2);
      botCtx.clip();

      // Dark base (unlit side)
      botCtx.fillStyle = '#05090f';
      botCtx.fillRect(cx - R - 1, cy - R - 1, R * 2 + 2, R * 2 + 2);

      const illumination = (1 - Math.cos(Math.PI * 2 * (phase.index / 8))) / 2;
      if (illumination > 0.01) {
        const waxing = phase.index <= 4;
        const hx     = cx + R * (waxing ? 0.2 : -0.2);
        const hy     = cy - R * 0.25;

        const sphereGrad = botCtx.createRadialGradient(hx, hy, R * 0.05, cx, cy, R);
        sphereGrad.addColorStop(0,    '#f0f5ff');
        sphereGrad.addColorStop(0.3,  '#d0dff5');
        sphereGrad.addColorStop(0.65, '#8898cc');
        sphereGrad.addColorStop(1,    '#3a4a90');

        // Terminator curve — positive = gibbous, negative = crescent
        const tX = R * (2 * illumination - 1) * (waxing ? 1 : -1);

        botCtx.beginPath();
        botCtx.moveTo(cx, cy - R);
        waxing
          ? botCtx.arc(cx, cy, R, -Math.PI / 2, Math.PI / 2, false)
          : botCtx.arc(cx, cy, R, -Math.PI / 2, Math.PI / 2, true);

        botCtx.bezierCurveTo(cx + tX * K, cy + R,     cx + tX, cy + R * K, cx + tX, cy);
        botCtx.bezierCurveTo(cx + tX,     cy - R * K, cx + tX * K, cy - R, cx, cy - R);
        botCtx.fillStyle = sphereGrad;
        botCtx.fill();

        // Edge vignette
        const vignette = botCtx.createRadialGradient(cx, cy, 0, cx, cy, R);
        vignette.addColorStop(0,    'rgba(0,0,0,0)');
        vignette.addColorStop(0.65, 'rgba(0,0,0,0.015)');
        vignette.addColorStop(1,    'rgba(0,0,20,0.12)');
        botCtx.fillStyle = vignette;
        botCtx.beginPath();
        botCtx.arc(cx, cy, R, 0, Math.PI * 2);
        botCtx.fill();
      }

      botCtx.restore(); // remove clip

      // Limb ring
      botCtx.beginPath();
      botCtx.arc(cx, cy, R - 0.5, 0, Math.PI * 2);
      botCtx.strokeStyle = 'rgba(220,235,255,0.22)';
      botCtx.lineWidth   = 1;
      botCtx.stroke();

      botCtx.restore(); // remove globalAlpha
    }

    function drawLeftSun(now) {
      const W     = botCanvas.width;
      const H     = botCanvas.height;
      const halfW = W * 0.5;
      const cx    = halfW * 0.5;
      const cy    = H * 0.5 + Math.sin(now * 0.0008) * H * 0.06;
