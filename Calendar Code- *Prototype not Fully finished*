        botCtx.beginPath();
        botCtx.arc((x / 1280) * W, (y / 116) * H, 1.1, 0, Math.PI * 2);
        botCtx.fill();
      });

      // Left half — sun and weather
      drawLeftSun(now);
      drawWeatherClouds(now);

      // Moon arc
      drawMoonArcTrack();

      const moonProg = getMoonProgress();
      const moonVis  = moonProg >= 0 && moonProg <= 1;
      const moonOp   = moonVis ? Math.min(1, Math.min(moonProg, 1 - moonProg) * 14) : 0;
      const phase    = getMoonPhase(today.getFullYear(), today.getMonth() + 1, today.getDate());

      document.getElementById('moon-phase-name').textContent = phase.name;

      if (moonVis) {
        drawMoonTrail(moonProg);
        const pt = moonArcPoint(moonProg);
        drawMoonDisc(pt.x, pt.y, Math.max(14, H * 0.28), phase, Math.max(0.15, moonOp));
      }
    }
    function onResize() {
      resizeSkyCanvas();
      resizeBotCanvas();
      drawSilk();
    }

    window.addEventListener('resize', onResize);

    resizeSkyCanvas();
    resizeBotCanvas();
    drawSilk();

    function tick() {
      drawSky();
      updateSunArc();
      drawBotCanvas();
      requestAnimationFrame(tick);
    }

    tick();
  </script>
</body>
</html>
