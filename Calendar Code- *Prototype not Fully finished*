    function bezierPoint(t, x0, y0, cx, cy, x1, y1) {
      const u = 1 - t;
      return {
        x: u * u * x0 + 2 * u * t * cx + t * t * x1,
        y: u * u * y0 + 2 * u * t * cy + t * t * y1,
      };
    }

    /** Returns the SVG path string for the arc traveled up to progress t */
    function subBezierPath(t, x0, y0, cx, cy, x1, y1) {
      if (t <= 0) return '';
      const mid  = bezierPoint(t / 2, x0, y0, cx, cy, x1, y1);
      const end  = bezierPoint(t,     x0, y0, cx, cy, x1, y1);
      const scpx = 2 * mid.x - 0.5 * (x0 + end.x);
      const scpy = 2 * mid.y - 0.5 * (y0 + end.y);
      return `M ${x0} ${y0} Q ${scpx.toFixed(2)} ${scpy.toFixed(2)} ${end.x.toFixed(2)} ${end.y.toFixed(2)}`;
    }
    const skyCanvas = document.getElementById('sky-canvas');
    const skyCtx    = skyCanvas.getContext('2d');

    function resizeSkyCanvas() {
      skyCanvas.width  = window.innerWidth;
      skyCanvas.height = window.innerHeight * 0.855;
    }

    function skyGradientColors(minuteOfDay) {
      const t  = minuteOfDay / 1440;
      const sr = SUN_RISE / 1440;
      const ss = SUN_SET  / 1440;

      if (t < sr - 0.04) return ['#060c08', '#0a1410', '#08100c'];
      if (t < sr)        return ['#0c1a14', '#1a2830', '#b04030'];
      if (t < sr + 0.05) return ['#142818', '#906030', '#e89040'];
      if (t < 0.45)      return ['#1a4c88', '#2878b8', '#4a9ac8'];
      if (t < ss - 0.05) return ['#163070', '#2060a0', '#3480b8'];
      if (t < ss)        return ['#182020', '#803020', '#c05030'];
      if (t < ss + 0.04) return ['#100c10', '#401828', '#802020'];
      return                    ['#060c08', '#0a1410', '#08100c'];
    }
    const STARS = [
      [110,35],[260,65],[430,28],[580,52],[740,22],[900,65],[1090,35],[1190,85],
      [55,100],[340,140],[690,105],[1040,125],[190,185],[540,175],[890,170],[1140,190],
      [75,250],[395,240],[750,230],[1090,250],[290,300],[640,295],[980,285],
      [160,55],[480,78],[720,40],[960,90],[1150,50],[30,180],[350,210],[680,220],
      [1000,195],[1210,230],[420,310],[760,320],[1080,305],[200,340],[580,355],
    ];

    const BRIGHT_STARS = [
      [200,42],[520,18],[850,38],[1150,22],[310,120],[750,95],[1050,140],[460,270],[900,260],
    ];

    function getSunProgress() {
      const now     = new Date();
      const minutes = now.getHours() * 60 + now.getMinutes() + now.getSeconds() / 60;
      if (minutes <= SUN_RISE) return 0;
      if (minutes >= SUN_SET)  return 1;
      return (minutes - SUN_RISE) / (SUN_SET - SUN_RISE);
    }

    function drawSky() {
      const { width: W, height: H } = skyCanvas;
      const now     = new Date();
      const minutes = now.getHours() * 60 + now.getMinutes() + now.getSeconds() / 60;
      const [top, mid, bot] = skyGradientColors(minutes);
      const grad = skyCtx.createLinearGradient(0, 0, 0, H);
      grad.addColorStop(0, top);
      grad.addColorStop(0.5, mid);
      grad.addColorStop(1, bot);
      skyCtx.fillStyle = grad;
      skyCtx.fillRect(0, 0, W, H);
      const sp     = getSunProgress();
      const nightA = sp < 0.06 ? (0.06 - sp) / 0.06 : sp > 0.94 ? (sp - 0.94) / 0.06 : 0;
      const starA  = Math.max(0.55, nightA * 0.92);

      STARS.forEach(([x, y]) => {
        skyCtx.fillStyle = `rgba(255,255,255,${starA})`;
        skyCtx.beginPath();
        skyCtx.arc((x / 1280) * W, (y / 600) * H, 1.2, 0, Math.PI * 2);
        skyCtx.fill();
      });

      BRIGHT_STARS.forEach(([x, y]) => {
        skyCtx.fillStyle = `rgba(255,255,255,${Math.max(starA + 0.2, nightA)})`;
        skyCtx.beginPath();
        skyCtx.arc((x / 1280) * W, (y / 600) * H, 1.8, 0, Math.PI * 2);
        skyCtx.fill();
      });
    }

    const sunArcEls = {
      hBloom:  document.getElementById('horizon-bloom'),
      hbg0:    document.getElementById('horizon-bloom-inner'),
      trail:   document.getElementById('sun-trail'),
      haze:    document.getElementById('sun-haze-el'),
