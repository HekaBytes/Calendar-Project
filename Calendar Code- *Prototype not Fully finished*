      corona.addColorStop(1,   'rgba(255,140,40,0)');
      botCtx.fillStyle = corona;
      botCtx.beginPath(); botCtx.arc(cx, cy, R * 2.2, 0, Math.PI * 2); botCtx.fill();

      const halo = botCtx.createRadialGradient(cx, cy, R * 0.2, cx, cy, R * 1.1);
