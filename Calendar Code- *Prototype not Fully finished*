<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Garden Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
  <style>

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      /* Layout */
      --header-h: 6.75vh;
      --bar-h:    14.5vh;
      --col-h:    calc(100vh - var(--header-h) - var(--bar-h));

      /* Z-index scale */
      --z-canvas:  0;
      --z-silk:    1;
      --z-sun-arc: 2;
      --z-ui:      5;

      /* Palette — Thai Constellation */
      --color-jade:       #7bc49a;
      --color-jade-light: #a8dbb8;
      --color-sage:       #c8ddc0;
      --color-fern:       #e2f0e0;
      --color-ivory:      #f8f4ec;
      --color-gold:       #c8a84a;
      --color-gold-light: #e8c870;
      --color-teal:       #68b8cc;
      --color-teal-light: #98d8e8;
      --color-alert:      #d05848;
      --color-moon:       #e8f0ff;

      /* Semantic aliases */
      --text-primary:   var(--color-ivory);
      --text-secondary: var(--color-fern);
      --text-dim:       rgba(200, 225, 200, 0.50);
      --text-dimmer:    rgba(200, 225, 200, 0.25);
      --text-moon:      var(--color-moon);
      --text-moon-dim:  rgba(220, 230, 255, 0.55);

      --surface-card:       rgba(18, 28, 20, 0.46);
      --surface-card-today: rgba(28, 50, 34, 0.72);
      --surface-bar-right:  rgba(3, 6, 10, 0.55);

      --border-default:  rgba(155, 205, 165, 0.18);
      --border-emphasis: rgba(155, 205, 165, 0.55);

      /* Task chip accent colors */
      --chip-water: rgba(88,  180, 216, 0.40);
      --chip-feed:  rgba(200, 168,  74, 0.40);
      --chip-prune: rgba(120, 200, 128, 0.40);
      --chip-alert: rgba(224,  88,  72, 0.52);

      /* Radii */
      --radius-card: 1.2vh;
      --radius-chip: 0.8vh;
      --radius-btn:  50%;
    }


    html, body {
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: #0a1210;
      font-family: 'JetBrains Mono', monospace;
      color: var(--text-secondary);
      -webkit-font-smoothing: antialiased;
      user-select: none;
    }

    /* Silk sheen — single static diagonal light catch */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: var(--z-silk);
      pointer-events: none;
      background: linear-gradient(
        118deg,
        transparent 0%,
        transparent 28%,
        rgba(210, 235, 215, 0.05) 44%,
        rgba(215, 240, 220, 0.08) 50%,
        rgba(210, 235, 215, 0.05) 56%,
        transparent 72%,
        transparent 100%
      );
    }

    #sky-canvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: calc(100vh - var(--bar-h));
      z-index: var(--z-canvas);
      pointer-events: none;
    }

    #silk-canvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      z-index: var(--z-silk);
      pointer-events: none;
      opacity: 0.75;
      mix-blend-mode: soft-light;
    }

    #sun-arc-svg {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: calc(100vh - var(--bar-h));
      z-index: var(--z-sun-arc);
      pointer-events: none;
    }

    .app {
      position: relative;
      width: 100vw;
      height: 100vh;
      display: flex;
      flex-direction: column;
      z-index: var(--z-ui);
    }

    .header {
      height: var(--header-h);
      flex-shrink: 0;
      display: grid;
      grid-template-columns: 80px 1fr 80px;
      align-items: center;
      padding: 0 1.4vw;
    }

    .header__nav-btn {
      width: 5.5vh;
      height: 5.5vh;
      min-width: 36px;
      min-height: 36px;
      border-radius: var(--radius-btn);
      border: 1px solid var(--border-default);
      background: rgba(18, 28, 20, 0.65);
      color: var(--color-sage);
      font-size: clamp(0.85rem, 1.1vw, 1.1rem);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(8px);
      transition: background 0.18s, color 0.18s, transform 0.18s;
      -webkit-tap-highlight-color: transparent;
    }

    .header__nav-btn:active {
      background: var(--surface-card-today);
      color: var(--color-jade-light);
      transform: scale(0.93);
    }

    .header__prev { justify-self: start; }
    .header__next { justify-self: end; }

    .header__title {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .header__month {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4.8vh, 3.2rem);
      font-weight: 300;
      color: var(--text-primary);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      line-height: 1;
    }

    .header__daterange {
      font-size: clamp(0.48rem, 0.75vh, 0.62rem);
      letter-spacing: 0.2em;
      color: var(--text-dim);
      text-transform: uppercase;
      margin-top: 0.3vh;
    }

    .columns {
      height: var(--col-h);
      flex-shrink: 0;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.45vw;
      padding: 0 1.4vw 0.8vh;
    }

    .day-col {
      display: flex;
      flex-direction: column;
      background: var(--surface-card);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-card);
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.2s;
      -webkit-tap-highlight-color: transparent;
      min-width: 0;
      min-height: 0;
      animation: fade-up 0.4s ease both;
    }

    .day-col--today {
      background: var(--surface-card-today);
      border-color: var(--border-emphasis);
      box-shadow:
        0 0 0 1px rgba(140, 200, 120, 0.2) inset,
        0 2px 2.5vh rgba(82, 179, 106, 0.15);
    }

    .day-col--past    { opacity: 0.48; }
    .day-col:active   { border-color: var(--border-emphasis); }

    .day-col:nth-child(1) { animation-delay: 0.03s; }
    .day-col:nth-child(2) { animation-delay: 0.08s; }
    .day-col:nth-child(3) { animation-delay: 0.13s; }
    .day-col:nth-child(4) { animation-delay: 0.18s; }
    .day-col:nth-child(5) { animation-delay: 0.23s; }

    /* Column header */
    .col-head {
      flex-shrink: 0;
      padding: 1vh 0.8vw 0.7vh;
      border-bottom: 1px solid var(--border-default);
    }

    .col-head__dow {
      font-size: clamp(0.42rem, 0.5vw, 0.54rem);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    .day-col--today .col-head__dow { color: var(--color-jade-light); }

    .col-head__date {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 2.6vh, 2.2rem);
      font-weight: 300;
      color: var(--text-secondary);
      line-height: 1;
      margin-top: 0.2vh;
    }

    .day-col--today .col-head__date { color: var(--color-jade-light); }

    .col-head__moon {
      height: 1.8vh;
      min-height: 14px;
      display: flex;
      align-items: center;
      gap: 3px;
      margin-top: 0.3vh;
    }

    .col-head__moon-icon { font-size: clamp(0.6rem, 1vh, 0.85rem); }

    .col-head__moon-label {
      font-size: clamp(0.38rem, 0.55vh, 0.46rem);
      color: var(--text-moon);
      opacity: 0.72;
      letter-spacing: 0.06em;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    /* Column body */
    .col-body {
      flex: 1;
      min-height: 0;
      padding: 0.6vh 0.55vw 0.5vh;
      display: flex;
      flex-direction: column;
      gap: 0.5vh;
      overflow: hidden;
    }

    .col-body--clear {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: clamp(0.4rem, 0.55vw, 0.5rem);
      color: var(--text-dimmer);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    /* Task chips */
    .chip {
      display: flex;
      align-items: center;
      gap: 0.4vw;
      padding: 0.55vh 0.5vw;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      min-height: 3.8vh;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
    }

    .chip--water { border-color: var(--chip-water); }
    .chip--feed  { border-color: var(--chip-feed); }
    .chip--prune { border-color: var(--chip-prune); }
    .chip--alert { border-color: var(--chip-alert); }
    .chip:active { background: rgba(255, 255, 255, 0.07); }

    .chip__icon {
      font-size: clamp(0.75rem, 1.4vh, 1rem);
      width: 1.5vw;
      min-width: 16px;
      text-align: center;
      flex-shrink: 0;
    }

    .chip__info  { flex: 1; min-width: 0; }

    .chip__name {
      font-size: clamp(0.44rem, 0.65vw, 0.58rem);
      color: var(--text-secondary);
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .chip__task {
      font-size: clamp(0.38rem, 0.5vw, 0.49rem);
      color: var(--text-dim);
      margin-top: 0.15vh;
      white-space: nowrap;
    }

    .chip__pip {
      width: 0.4vw;
      height: 0.4vw;
      min-width: 5px;
      min-height: 5px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .chip__pip--water { background: var(--color-teal); }
    .chip__pip--feed  { background: var(--color-gold); }
    .chip__pip--prune { background: var(--color-jade); }
    .chip__pip--alert {
      background: var(--color-alert);
      box-shadow: 0 0 5px rgba(224, 88, 72, 0.7);
    }

    /* Column footer */
    .col-foot {
      flex-shrink: 0;
      padding: 0.5vh 0.7vw 0.75vh;
      border-top: 1px solid var(--border-default);
    }

    .soil-row {
      display: flex;
      align-items: center;
      gap: 0.4vw;
    }

    .soil-row__label {
      font-size: clamp(0.38rem, 0.5vw, 0.46rem);
      color: var(--text-dimmer);
      flex-shrink: 0;
    }

    .soil-row__track {
      flex: 1;
      height: 3px;
      background: rgba(255, 255, 255, 0.07);
      border-radius: 2px;
      overflow: hidden;
    }

    .soil-row__fill {
      height: 100%;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--color-teal), var(--color-teal-light));
      transition: width 0.4s;
    }

    .soil-row__fill--low { background: linear-gradient(90deg, var(--color-alert), #f08070); }
    .soil-row__fill--med { background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light)); }


    .bottom-bar {
      height: var(--bar-h);
      flex-shrink: 0;
      position: relative;
      overflow: hidden;
      border-top: 1px solid rgba(155, 205, 165, 0.15);
      animation: fade-up 0.4s 0.3s ease both;
    }

    #bot-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .bottom-bar__divider {
      position: absolute;
      top: 0;
      right: 50%;
      width: 1px;
      height: 100%;
      background: rgba(155, 205, 165, 0.10);
      z-index: 1;
      pointer-events: none;
    }

    /* Left half — weather + temp */
    .bar-weather {
      position: absolute;
      inset: 0 50% 0 0;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }

    .bar-weather__temp {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 6.5vh, 5rem);
      font-weight: 300;
      color: var(--color-gold);
      line-height: 1;
      letter-spacing: -0.03em;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.9), 0 0 40px rgba(200, 168, 74, 0.2);
    }

    .bar-weather__condition {
      font-size: clamp(0.5rem, 0.8vh, 0.65rem);
      color: var(--text-dim);
      letter-spacing: 0.1em;
      margin-top: 0.4vh;
      text-shadow: 0 1px 6px rgba(0, 0, 0, 0.8);
    }

    .bar-weather__moon-phase {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.6rem, 1.1vh, 0.82rem);
      font-style: italic;
      font-weight: 300;
      color: var(--text-moon);
      letter-spacing: 0.04em;
      margin-top: 0.5vh;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.9);
    }

    /* Right half — clock */
    .bar-clock {
      position: absolute;
      inset: 0 0 0 50%;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }

    .bar-clock__time {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 7vh, 5.5rem);
      font-weight: 300;
      color: var(--text-primary);
      line-height: 1;
      letter-spacing: -0.03em;
      text-shadow: 0 2px 22px rgba(0, 0, 0, 0.9);
    }

    .bar-clock__day {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.7rem, 1.2vh, 0.95rem);
      font-weight: 300;
      font-style: italic;
      color: var(--text-dim);
      letter-spacing: 0.06em;
      margin-top: 0.35vh;
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.8);
    }


    @keyframes fade-up {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <!-- Canvas layers (behind everything) -->
  <canvas id="sky-canvas"></canvas>
  <canvas id="silk-canvas"></canvas>

  <!-- Sun arc SVG overlay -->
  <svg id="sun-arc-svg" viewBox="0 0 1000 100" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <filter id="sun-glow" x="-120%" y="-120%" width="340%" height="340%">
        <feGaussianBlur stdDeviation="10" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="sun-haze" x="-300%" y="-300%" width="700%" height="700%">
        <feGaussianBlur stdDeviation="25"/>
      </filter>
      <radialGradient id="horizon-bloom-grad" cx="50%" cy="100%" r="55%">
        <stop offset="0%"   id="horizon-bloom-inner" stop-color="#f5a04a" stop-opacity="0.36"/>
        <stop offset="100%"                           stop-color="#f5a04a" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <ellipse id="horizon-bloom" cx="500" cy="108" rx="480" ry="120" fill="url(#horizon-bloom-grad)" opacity="0"/>
    <path d="M 20 97 Q 500 -12 980 97" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="1" stroke-dasharray="4 7"/>
    <path id="sun-trail" d="" fill="none" stroke="rgba(245,195,100,0.5)" stroke-width="2" stroke-linecap="round"/>
    <circle id="sun-haze-el" cx="0" cy="0" r="32" fill="#f5c870" filter="url(#sun-haze)" opacity="0"/>
    <circle id="sun-disc"    cx="0" cy="0" r="10" fill="#fff8e0" filter="url(#sun-glow)"  opacity="0"/>
    <circle id="sun-core"    cx="0" cy="0" r="4.5" fill="#ffffff"                          opacity="0"/>
  </svg>

  <!-- App shell -->
  <div class="app">

    <header class="header">
      <button class="header__nav-btn header__prev" id="btn-prev" aria-label="Previous period">‹</button>
      <div class="header__title">
        <h1 class="header__month"      id="header-month">March</h1>
        <p  class="header__daterange"  id="header-dates">–</p>
      </div>
      <button class="header__nav-btn header__next" id="btn-next" aria-label="Next period">›</button>
    </header>

    <main class="columns" id="columns" role="list"></main>

    <section class="bottom-bar" aria-label="Weather and time">
      <canvas id="bot-canvas"></canvas>
      <div class="bottom-bar__divider" aria-hidden="true"></div>

      <div class="bar-weather">
        <div class="bar-weather__temp">62°</div>
        <div class="bar-weather__condition">Partly Cloudy · Feels 59°F</div>
        <div class="bar-weather__moon-phase" id="moon-phase-name">–</div>
      </div>

      <div class="bar-clock">
        <div class="bar-clock__time" id="clock-time">–</div>
        <div class="bar-clock__day"  id="clock-day">–</div>
      </div>
    </section>

  </div>

  <script>
    'use strict';

 
    const DAYS_FULL  = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const MONTHS     = ['January','February','March','April','May','June','July','August','September','October','November','December'];

    // Sun timing (minutes since midnight)
    const SUN_RISE  = 6 * 60 + 42;   // 6:42 AM
    const SUN_SET   = 18 * 60 + 20;  // 6:20 PM

    // Moon timing
    const MOON_RISE     = 21 * 60 + 18;      // 9:18 PM
    const MOON_SET_NEXT = 8  * 60 + 4 + 1440; // 8:04 AM next day (in minutes)
    const MOON_DUR      = MOON_SET_NEXT - MOON_RISE;

    // Sun arc control points (SVG viewBox 0 0 1000 100)
    const SUN_ARC = { x0: 20, y0: 97, cx: 500, cy: -12, x1: 980, y1: 97 };

    const WEATHER = 'partly-cloudy'; // 'clear' | 'partly-cloudy' | 'cloudy' | 'overcast' | 'rain'

    const PLANTS = [
      { icon: '🌿', name: 'Monstera',          moisture: 14 },
      { icon: '🌵', name: 'Cactus',            moisture: 78 },
      { icon: '🌺', name: 'Bird of Paradise',  moisture: 44 },
      { icon: '🍃', name: 'Pothos',            moisture: 31 },
      { icon: '🌱', name: 'Basil',             moisture: 62 },
      { icon: '🌹', name: 'Rose Bush',         moisture: 55 },
      { icon: '🪴', name: 'Fiddle Leaf',       moisture: 48 },
    ];

    const TASK_LABELS = {
      water: '💧 water',
      feed:  '🌿 feed',
      prune: '✂️ prune',
      alert: '⚠️ check',
    };

    /** Returns pseudo-random tasks for 5 days starting at weekStart */
    function getWeekTasks(weekStart) {
      const tasks = Array.from({ length: 5 }, () => []);
      const base  = new Date(weekStart);

      for (let d = 0; d < 5; d++) {
        const n = base.getDate();
        if ((n + d)     % 3  === 0) tasks[d].push({ plant: 0, type: 'water' });
        if ((n + d + 1) % 4  === 0) tasks[d].push({ plant: 3, type: 'water' });
        if ((n + d + 2) % 5  === 0) tasks[d].push({ plant: 4, type: 'feed'  });
        if ((n + d)     % 7  === 0) tasks[d].push({ plant: 2, type: 'prune' });
        if ((n + d + 3) % 11 === 0) tasks[d].push({ plant: 6, type: 'alert' });
        base.setDate(base.getDate() + 1);
      }

      return tasks;
    }


    const MOON_PHASES = [
      { icon: '🌑', name: 'New Moon'        },
      { icon: '🌒', name: 'Waxing Crescent' },
      { icon: '🌓', name: 'First Quarter'   },
      { icon: '🌔', name: 'Waxing Gibbous'  },
      { icon: '🌕', name: 'Full Moon'       },
      { icon: '🌖', name: 'Waning Gibbous'  },
      { icon: '🌗', name: 'Third Quarter'   },
      { icon: '🌘', name: 'Waning Crescent' },
    ];

    function getMoonPhase(year, month, day) {
      const REF_DATE = new Date(2026, 1, 25); // known new moon reference
      const SYNODIC  = 29.53;
      const elapsed  = new Date(year, month - 1, day) - REF_DATE;
      const age      = ((elapsed / 86400000) % SYNODIC + SYNODIC) % SYNODIC;

      let index, illumination, notable = false;

      if      (age < 1.85)  { index = 0; illumination = 0;   notable = true; }
      else if (age < 7.38)  { index = 1; illumination = Math.round(age / 7.38 * 49); }
      else if (age < 9.22)  { index = 2; illumination = 50;  notable = true; }
      else if (age < 14.77) { index = 3; illumination = Math.round(50 + (age - 9.22) / 5.55 * 49); }
      else if (age < 16.61) { index = 4; illumination = 100; notable = true; }
      else if (age < 22.15) { index = 5; illumination = Math.round(100 - (age - 16.61) / 5.54 * 49); }
      else if (age < 23.99) { index = 6; illumination = 50;  notable = true; }
      else                  { index = 7; illumination = Math.round((SYNODIC - age) / 5.54 * 49); }

      return { ...MOON_PHASES[index], index, illumination, notable };
    }

    const today       = new Date();
    const todayMidnight = new Date(today); todayMidnight.setHours(0, 0, 0, 0);
    let   windowOffset = 0; // days offset from today

    function getWindowStart() {
      const d = new Date(today);
      d.setDate(today.getDate() + windowOffset);
      d.setHours(0, 0, 0, 0);
      return d;
    }

    function renderWeek() {
      const start = getWindowStart();
      const end   = new Date(start); end.setDate(start.getDate() + 4);

      const startMonth = MONTHS[start.getMonth()];
      const endMonth   = MONTHS[end.getMonth()];
      document.getElementById('header-month').textContent =
        startMonth === endMonth ? startMonth : `${startMonth} · ${endMonth}`;
