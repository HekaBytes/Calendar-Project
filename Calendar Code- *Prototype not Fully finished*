      botCtx.fillStyle = halo;
      botCtx.beginPath(); botCtx.arc(cx, cy, R * 1.1, 0, Math.PI * 2); botCtx.fill();

      const disc = botCtx.createRadialGradient(cx - R * 0.15, cy - R * 0.15, R * 0.05, cx, cy, R);
      disc.addColorStop(0,    '#fff8e8');
