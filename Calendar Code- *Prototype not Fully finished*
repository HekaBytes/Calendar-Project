    };

    function updateSunArc() {
      const { x0, y0, cx, cy, x1, y1 } = SUN_ARC;
      const sp  = getSunProgress();
      const pt  = bezierPoint(sp, x0, y0, cx, cy, x1, y1);
      const vis = sp > 0 && sp < 1;
      const op  = vis ? Math.min(1, Math.min(sp, 1 - sp) * 18) : 0;

      [sunArcEls.haze, sunArcEls.disc, sunArcEls.core].forEach(el => {
        el.setAttribute('cx', pt.x.toFixed(2));
        el.setAttribute('cy', pt.y.toFixed(2));
      });
      sunArcEls.haze.setAttribute('opacity', (op * 0.5).toString());
      sunArcEls.disc.setAttribute('opacity', op.toString());
      sunArcEls.core.setAttribute('opacity', op.toString());

      const bloomOp = vis
        ? (Math.pow(1 - Math.abs(sp - 0.5) * 2, 2) * 0.45 + 0.04).toFixed(3)
        : '0';
      sunArcEls.hBloom.setAttribute('opacity', bloomOp);
      sunArcEls.hbg0.setAttribute('stop-color', (sp < 0.15 || sp > 0.85) ? '#f57040' : '#f5b040');
      sunArcEls.trail.setAttribute('d', subBezierPath(sp, x0, y0, cx, cy, x1, y1));
      sunArcEls.trail.setAttribute('opacity', vis ? '1': '0');
    }

