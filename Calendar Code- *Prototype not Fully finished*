      'partly-cloudy': [[0.72, 0.32, 0.22, 0.82, 0.00018, 0.03], [0.28, 0.55, 0.16, 0.60, -0.00014, 0.025]],
      'cloudy':        [[0.60, 0.28, 0.26, 0.90, 0.00016, 0.03], [0.22, 0.50, 0.20, 0.80, -0.00012, 0.025], [0.82, 0.55, 0.18, 0.70, 0.00020, 0.02]],
      'overcast':      [[0.50, 0.22, 0.32, 0.95, 0.00010, 0.015],[0.20, 0.48, 0.28, 0.88, -0.00008, 0.012],[0.78, 0.45, 0.24, 0.85, 0.00014, 0.018],[0.40, 0.62, 0.20, 0.75, -0.00012, 0.01]],
      'rain':          [[0.50, 0.20, 0.30, 0.92, 0.00008, 0.01], [0.25, 0.42, 0.24, 0.85, -0.00006, 0.01],[0.76, 0.40, 0.22, 0.80, 0.00010, 0.01]],
